*.pdf -text

# Committed snapshot baselines must stay LF-terminated even when checked
# out on Windows. Without this Git's autocrlf=true converts LF→CRLF and
# the snapshot tests (`compat_baseline_static_id`, `compat_matrix_baseline`)
# read CRLF but compare against LF-rendered markdown.
tests/golden/*.md text eol=lf

# show-linearization text goldens are compared byte-for-byte against the
# decoder's LF-terminated dump. Git autocrlf=true on Windows must NOT rewrite
# them to CRLF or show_linearization_tests (one/two/three_page_dump_matches_
# text_golden) read CRLF and diverge from the LF dump.
tests/golden/references/**/show-linearization.txt text eol=lf

# QDF fixtures are byte-exact golden artifacts (fix_qdf recomputes
# xref offsets/lengths from raw bytes). Git autocrlf on Windows must NOT
# rewrite their line endings or the byte-for-byte golden comparisons
# (qdf_fix_tests: matches_oracle_golden_byte_for_byte, no_op_on_clean_qdf)
# fail. Treat as binary, same as *.pdf.
*.qdf -text
